{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"target/**"
			],
			"cache": true
		},
		"lint": {
			"dependsOn": [
				"build"
			],
			"cache": false
		},
		"format": {
			"inputs": [
				"$TURBO_DEFAULT$",
				"//.prettierrc",
				"pom.xml"
			],
			"cache": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}